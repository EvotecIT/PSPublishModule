{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "powerforge.common.schema.json",
  "title": "PowerForge Common Types (schema v1)",
  "type": "object",
  "$defs": {
    "InstallationStrategy": {
      "type": "string",
      "enum": ["Exact", "AutoRevision"]
    },
    "LegacyFlatModuleHandling": {
      "type": "string",
      "enum": ["Warn", "Convert", "Delete", "Ignore"]
    },
    "ModuleTestSuiteOutputFormat": {
      "type": "string",
      "enum": ["Detailed", "Normal", "Minimal"]
    },
    "PublishDestination": {
      "type": "string",
      "enum": ["PowerShellGallery", "GitHub"]
    },
    "PublishTool": {
      "type": "string",
      "enum": ["Auto", "PSResourceGet", "PowerShellGet"]
    },
    "ModuleSaveTool": {
      "type": "string",
      "enum": ["Auto", "PSResourceGet", "PowerShellGet"]
    },
    "RequiredModulesSource": {
      "type": "string",
      "enum": ["Auto", "Installed", "Download"]
    },
    "RepositoryApiVersion": {
      "type": "string",
      "enum": ["Auto", "Local", "NugetServer", "V2", "V3", "ContainerRegistry"]
    },
    "ModuleDependencyKind": {
      "type": "string",
      "enum": ["RequiredModule", "ExternalModule", "ApprovedModule"]
    },
    "ArtefactType": {
      "type": "string",
      "enum": ["Unpacked", "Packed", "Script", "ScriptPacked"]
    },
    "FileConsistencyEncoding": {
      "type": "string",
      "enum": ["ASCII", "UTF8", "UTF8BOM", "Unicode", "BigEndianUnicode", "UTF7", "UTF32"]
    },
    "FileConsistencyLineEnding": {
      "type": "string",
      "enum": ["CRLF", "LF"]
    },
    "FileConsistencyScope": {
      "type": "string",
      "enum": ["StagingOnly", "ProjectOnly", "StagingAndProject"]
    },
    "ProjectKind": {
      "type": "string",
      "enum": ["PowerShell", "CSharp", "Mixed", "All"]
    },
    "DeliveryBundleDestination": {
      "type": "string",
      "enum": ["Internals", "Root", "Both", "None"]
    },
    "TestExecutionWhen": {
      "type": "string",
      "enum": ["AfterMerge"]
    },
    "ModulePipelineActionStage": {
      "type": "string",
      "enum": [
        "BeforeDependencies",
        "AfterDependencies",
        "BeforeVersioning",
        "AfterVersioning",
        "BeforeStaging",
        "AfterStaging",
        "BeforeBuild",
        "AfterBuild",
        "BeforeManifest",
        "AfterManifest",
        "BeforeDocumentation",
        "AfterDocumentation",
        "BeforeFormatting",
        "AfterFormatting",
        "BeforeValidation",
        "AfterValidation",
        "BeforeTests",
        "AfterTests",
        "BeforeSigning",
        "AfterSigning",
        "BeforeArtefacts",
        "AfterArtefacts",
        "BeforePublish",
        "AfterPublish",
        "BeforeInstall",
        "AfterInstall"
      ]
    },
    "ValidationSeverity": {
      "type": "string",
      "enum": ["Off", "Warning", "Error"]
    },
    "ApplePlatform": {
      "type": "string",
      "enum": ["iOS", "iPadOS", "macOS", "tvOS", "watchOS", "visionOS"]
    },
    "AppleBuildNumberPolicy": {
      "type": "string",
      "enum": ["Explicit", "KeepExisting", "IncrementExisting"]
    }
  }
}
