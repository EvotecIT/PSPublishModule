{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "powerforge.web.serverrecovery.schema.json",
  "title": "PowerForge Web Server Recovery Manifest (schema v2)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "integer", "minimum": 2, "maximum": 2 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "target": { "$ref": "#/$defs/Target" },
    "operationLocks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^/var/lock/[A-Za-z0-9][A-Za-z0-9_.-]{0,125}\\.lock$"
      }
    },
    "repositories": {
      "type": "array",
      "items": { "$ref": "#/$defs/Repository" }
    },
    "accounts": {
      "type": "array",
      "items": { "$ref": "#/$defs/Account" }
    },
    "packages": { "$ref": "#/$defs/Packages" },
    "paths": {
      "type": "array",
      "items": { "$ref": "#/$defs/ManagedPath" }
    },
    "apache": { "$ref": "#/$defs/Apache" },
    "firewall": { "$ref": "#/$defs/Firewall" },
    "certificates": {
      "type": "array",
      "items": { "$ref": "#/$defs/Certificate" }
    },
    "systemd": { "$ref": "#/$defs/Systemd" },
    "secrets": {
      "type": "array",
      "items": { "$ref": "#/$defs/Secret" }
    },
    "capture": { "$ref": "#/$defs/Capture" },
    "bootstrap": { "$ref": "#/$defs/CommandGroup" },
    "deploy": { "$ref": "#/$defs/Deploy" },
    "verify": { "$ref": "#/$defs/Verify" },
    "backupTarget": { "$ref": "#/$defs/BackupTarget" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["schemaVersion", "name", "target"],
  "allOf": [
    {
      "if": { "required": ["backupTarget"] },
      "then": {
        "required": ["capture"],
        "properties": {
          "capture": {
            "required": ["plainFiles", "encryptedFiles"],
            "properties": {
              "plainFiles": { "minItems": 1 },
              "encryptedFiles": { "minItems": 1 }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "AbsoluteUnixPath": {
      "type": "string",
      "pattern": "^/(?!\\.{1,2}(?:/|$))(?!.*/\\.{1,2}(?:/|$))(?!.*//)[A-Za-z0-9_./-]+$"
    },
    "AbsoluteUnixExactPath": {
      "type": "string",
      "pattern": "^/(?!\\.{1,2}(?:/|$))(?!.*/\\.{1,2}(?:/|$))(?!.*//)[A-Za-z0-9_./-]*[A-Za-z0-9_.-]$"
    },
    "Target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sshAlias": { "type": "string" },
        "host": { "type": "string" },
        "user": { "type": "string" },
        "sshPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "os": { "type": "string", "pattern": "^ubuntu(?:-[0-9]{2}\\.[0-9]{2})?$" },
        "architecture": { "type": "string", "enum": ["x64", "arm64"] }
      },
      "anyOf": [
        { "required": ["sshAlias"] },
        { "required": ["host"] }
      ]
    },
    "Repository": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "path": { "$ref": "#/$defs/AbsoluteUnixExactPath" },
        "branch": { "type": "string" },
        "ref": { "type": "string", "minLength": 1 },
        "refCaptureCommandId": { "type": "string", "pattern": "^[A-Za-z0-9_][A-Za-z0-9_-]{0,63}$" },
        "refCaptureCommandIds": {
          "type": "array",
          "minItems": 2,
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[A-Za-z0-9_][A-Za-z0-9_-]{0,63}$" }
        },
        "required": { "type": "boolean" },
        "sshIdentityFile": { "$ref": "#/$defs/AbsoluteUnixPath" },
        "sshKnownHostsFile": { "$ref": "#/$defs/AbsoluteUnixPath" },
        "bootstrapRequiredFiles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/AbsoluteUnixPath" }
        }
      },
      "dependentRequired": {
        "sshIdentityFile": ["sshKnownHostsFile", "bootstrapRequiredFiles"],
        "sshKnownHostsFile": ["sshIdentityFile", "bootstrapRequiredFiles"]
      },
      "not": { "required": ["refCaptureCommandId", "refCaptureCommandIds"] },
      "required": ["role", "path"]
    },
    "Account": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z_][a-z0-9_-]{0,31}$" },
        "system": { "type": "boolean" },
        "createHome": { "type": "boolean" },
        "home": { "type": "string" },
        "shell": { "type": "string" }
      },
      "required": ["name"]
    },
    "Packages": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "apt": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9+.:-]{0,127}$" }
        },
        "apacheModules": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$" }
        },
        "dotnetSdks": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(?:8|8\\.0|10|10\\.0)$" }
        },
        "powershell": { "type": "boolean" }
      }
    },
    "ManagedPath": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": {
          "allOf": [
            { "$ref": "#/$defs/AbsoluteUnixExactPath" },
            { "not": { "enum": ["/etc/sudoers", "/etc/sudoers.d"] } }
          ]
        },
        "source": { "$ref": "#/$defs/AbsoluteUnixExactPath" },
        "owner": { "type": "string", "pattern": "^[A-Za-z0-9_][A-Za-z0-9_-]{0,31}$" },
        "group": { "type": "string", "pattern": "^[A-Za-z0-9_][A-Za-z0-9_-]{0,31}$" },
        "mode": { "type": "string", "pattern": "^[0-7]{3,4}$" },
        "kind": {
          "type": "string",
          "enum": ["directory", "file", "symlink"]
        },
        "validation": {
          "type": "string",
          "enum": ["sudoers"]
        }
      },
      "required": ["id", "path"],
      "allOf": [
        {
          "if": { "required": ["source"] },
          "then": {
            "required": ["kind", "owner", "group", "mode"],
            "properties": {
              "kind": { "enum": ["file"] },
              "path": { "$ref": "#/$defs/AbsoluteUnixExactPath" }
            }
          }
        },
        {
          "if": { "properties": { "validation": { "enum": ["sudoers"] } }, "required": ["validation"] },
          "then": {
            "required": ["source", "owner", "group", "mode", "kind"],
            "properties": {
              "kind": { "enum": ["file"] },
              "owner": { "enum": ["root"] },
              "group": { "enum": ["root"] },
              "mode": { "enum": ["440", "0440"] },
              "path": { "pattern": "^/etc/sudoers\\.d/[A-Za-z0-9_-]+$" }
            }
          }
        },
        {
          "if": { "properties": { "path": { "pattern": "^/etc/sudoers\\.d/" } }, "required": ["path"] },
          "then": {
            "required": ["validation"],
            "properties": {
              "validation": { "enum": ["sudoers"] }
            }
          }
        }
      ]
    },
    "Apache": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "service": { "type": "string" },
        "modules": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$" }
        },
        "sites": {
          "type": "array",
          "items": { "$ref": "#/$defs/ApacheSiteFile" }
        },
        "conf": {
          "type": "array",
          "items": { "$ref": "#/$defs/ApacheConfFile" }
        },
        "validateCommand": { "type": "string" }
      }
    },
    "ManagedFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "required": { "type": "boolean" },
        "sensitive": { "type": "boolean" }
      },
      "required": ["target"]
    },
    "RepositoryManagedFile": {
      "allOf": [
        { "$ref": "#/$defs/ManagedFile" },
        {
          "properties": {
            "source": { "$ref": "#/$defs/AbsoluteUnixExactPath" },
            "target": {
              "allOf": [
                { "$ref": "#/$defs/AbsoluteUnixExactPath" },
                { "not": { "pattern": "^/etc/sudoers(?:$|\\.d(?:$|/))" } }
              ]
            }
          }
        }
      ]
    },
    "ApacheFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": { "$ref": "#/$defs/AbsoluteUnixExactPath" },
        "target": { "$ref": "#/$defs/AbsoluteUnixExactPath" },
        "required": { "type": "boolean" },
        "enabled": { "type": "boolean" }
      },
      "required": ["target"]
    },
    "ApacheSiteFile": {
      "allOf": [
        { "$ref": "#/$defs/ApacheFile" },
        {
          "properties": {
            "target": { "pattern": "^/etc/apache2/sites-available/[A-Za-z0-9][A-Za-z0-9_.-]{0,249}\\.conf$" }
          }
        }
      ]
    },
    "ApacheConfFile": {
      "allOf": [
        { "$ref": "#/$defs/ApacheFile" },
        {
          "properties": {
            "target": { "pattern": "^/etc/apache2/conf-available/[A-Za-z0-9][A-Za-z0-9_.-]{0,249}\\.conf$" }
          }
        }
      ]
    },
    "PlainCaptureFile": {
      "allOf": [
        { "$ref": "#/$defs/ManagedFile" },
        {
          "properties": {
            "sensitive": { "enum": [false] }
          }
        }
      ]
    },
    "EncryptedCaptureFile": {
      "allOf": [
        { "$ref": "#/$defs/ManagedFile" },
        {
          "properties": {
            "sensitive": { "enum": [true] }
          },
          "required": ["sensitive"]
        }
      ]
    },
    "Firewall": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string" },
        "defaultIncoming": { "type": "string" },
        "defaultOutgoing": { "type": "string" },
        "sshPorts": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 65535 }
        },
        "webOriginPolicy": { "type": "string" },
        "syncCommand": { "type": "string" }
      }
    },
    "Certificate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "authenticator": { "type": "string" },
        "credentialsPath": { "type": "string" },
        "renewalConfigPath": { "type": "string" },
        "dryRunCommand": { "type": "string" },
        "secretRefs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name"]
    },
    "Systemd": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "services": {
          "type": "array",
          "items": { "$ref": "#/$defs/SystemdUnit" }
        },
        "timers": {
          "type": "array",
          "items": { "$ref": "#/$defs/SystemdUnit" }
        }
      }
    },
    "SystemdUnit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9:_.@-]{0,246}\\.(service|timer)$"
        },
        "source": { "$ref": "#/$defs/AbsoluteUnixExactPath" },
        "target": {
          "allOf": [
            { "$ref": "#/$defs/AbsoluteUnixExactPath" },
            { "not": { "pattern": "^/etc/sudoers(?:$|\\.d(?:$|/))" } }
          ]
        },
        "enabled": { "type": "boolean" },
        "activation": {
          "type": "string",
          "enum": ["beforeDeploy", "afterDeploy"],
          "description": "Optionally start an enabled unit before or after declared deploy commands. Omit for legacy enable-only behavior."
        },
        "expectedState": {
          "type": "string",
          "enum": ["active", "inactive"],
          "description": "Optionally require the activated unit to settle in this systemctl is-active state during inspection. Omit for transient oneshot units whose steady state is not asserted."
        },
        "required": { "type": "boolean" }
      },
      "required": ["name"],
      "allOf": [
        {
          "if": { "required": ["activation"] },
          "then": {
            "required": ["enabled"],
            "properties": { "enabled": { "enum": [true] } }
          }
        },
        {
          "if": { "required": ["expectedState"] },
          "then": { "required": ["activation"] }
        }
      ]
    },
    "Secret": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string" },
        "env": { "type": "string" },
        "requiredFor": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiredDuringBootstrap": {
          "type": "boolean",
          "description": "Defaults to true. Set false only when a secret may be created after the initial bootstrap stage, such as first-issue certificate material."
        },
        "restoreAfterRepositories": {
          "type": "boolean",
          "description": "Stage this exact file during secret restore and install it only after pinned repositories are cloned."
        },
        "capture": {
          "type": "string",
          "enum": ["exclude", "encrypted"]
        },
        "restoreMode": { "type": "string", "enum": ["file", "directory"] },
        "owner": { "type": "string", "pattern": "^[A-Za-z0-9_][A-Za-z0-9_-]{0,31}$" },
        "group": { "type": "string", "pattern": "^[A-Za-z0-9_][A-Za-z0-9_-]{0,31}$" },
        "mode": { "type": "string", "pattern": "^[0-7]{3,4}$" }
      },
      "required": ["id", "capture"]
    },
    "Capture": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "plainFiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/PlainCaptureFile" }
        },
        "encryptedFiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/EncryptedCaptureFile" }
        },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/NamedCommand" }
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "CommandGroup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/NamedCommand" }
        }
      }
    },
    "Deploy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "operationLockOwner": {
          "type": "string",
          "enum": ["engine", "command"],
          "description": "Defaults to engine. Command ownership requires exactly one deploy command that holds every declared operation lock for its complete lifetime."
        },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/NamedCommand" }
        }
      }
    },
    "NamedCommand": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "workingDirectory": { "type": "string" },
        "sensitive": { "type": "boolean" },
        "required": { "type": "boolean" }
      },
      "required": ["id", "command"]
    },
    "Verify": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/NamedCommand" }
        },
        "urls": {
          "type": "array",
          "items": { "$ref": "#/$defs/VerifyUrl" }
        }
      }
    },
    "VerifyUrl": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "expectedStatus": { "type": "integer", "minimum": 100, "maximum": 599 },
        "via": { "type": "string" }
      },
      "required": ["url"]
    },
    "BackupTarget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["github"]
        },
        "repository": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "branch": {
          "type": "string",
          "pattern": "^(?!.*[\\r\\n])(?!/)(?!.*\\.\\.)[A-Za-z0-9_./-]+$"
        },
        "path": {
          "type": "string",
          "pattern": "^(?!.*[\\r\\n])(?!/)(?!.*\\.\\.)[A-Za-z0-9_./-]+$"
        },
        "encryption": {
          "type": "string",
          "enum": ["age"]
        },
        "recipient": { "type": "string", "minLength": 1 },
        "recipientEnv": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "retention": { "$ref": "#/$defs/BackupRetention" }
      },
      "required": ["type", "repository", "branch", "path", "encryption", "retention"],
      "anyOf": [
        { "required": ["recipient"] },
        { "required": ["recipientEnv"] }
      ]
    },
    "BackupRetention": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        { "required": ["keepLatestInTree"] },
        { "required": ["keepLatest"] }
      ],
      "not": { "required": ["keepLatestInTree", "keepLatest"] },
      "properties": {
        "keepLatestInTree": { "type": "integer", "minimum": 1, "maximum": 365 },
        "keepLatest": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365,
          "deprecated": true,
          "description": "Compatibility alias for keepLatestInTree. Git history is preserved."
        }
      }
    }
  }
}
