Cmnd_Alias __ALIAS___BACKUP_PLAIN = /usr/bin/tar -czf - __PLAIN_PATHS__
Cmnd_Alias __ALIAS___BACKUP_ENCRYPTED = /usr/bin/tar -czf - __ENCRYPTED_PATHS__
Cmnd_Alias __ALIAS___BACKUP_INSPECT = /usr/sbin/apachectl -S

__BACKUP_USER__ ALL=(root) NOPASSWD: __ALIAS___BACKUP_PLAIN, __ALIAS___BACKUP_ENCRYPTED, __ALIAS___BACKUP_INSPECT
