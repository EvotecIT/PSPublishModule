<Window x:Class="ReleaseOpsStudio.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ReleaseOpsStudio"
        Width="1480"
        Height="920"
        MinWidth="1200"
        MinHeight="760"
        Loaded="Window_Loaded">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,20,0"
                Background="{StaticResource AppAccentDeepBrush}"
                CornerRadius="28"
                Padding="22">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock FontFamily="Segoe UI Variable Display"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="ReleaseOps" />
                    <TextBlock Margin="0,6,0,22"
                               Foreground="#CBE3DD"
                               Text="Desktop release control plane" />

                    <Button Background="{StaticResource AppWarmBrush}"
                            BorderBrush="{StaticResource AppWarmBrush}"
                            Command="{Binding RefreshPortfolioCommand}"
                            Content="Prepare Queue" />
                    <Button Background="#1D5B52"
                            BorderBrush="#1D5B52"
                            Command="{Binding RunNextQueueStepCommand}"
                            Content="Run Next Step" />
                    <Button Background="#123C36"
                            BorderBrush="#123C36"
                            Command="{Binding ApproveUsbCommand}"
                            Content="Approve USB" />
                    <Button Background="#6C4A16"
                            BorderBrush="#6C4A16"
                            Command="{Binding RetryFailedCommand}"
                            Content="Retry Failed" />
                </StackPanel>

                <StackPanel VerticalAlignment="Stretch">
                    <TextBlock Margin="0,10,0,10"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#D8ECE7"
                               Text="Core Views" />
                    <TextBlock Margin="0,0,0,8" Foreground="White" Text="Portfolio" />
                    <TextBlock Margin="0,0,0,8" Foreground="#CBE3DD" Text="Queue" />
                    <TextBlock Margin="0,0,0,8" Foreground="#CBE3DD" Text="Repository Detail" />
                    <TextBlock Margin="0,0,0,8" Foreground="#CBE3DD" Text="Signing Station" />
                    <TextBlock Margin="0,0,0,8" Foreground="#CBE3DD" Text="Publish Station" />
                    <TextBlock Margin="0,0,0,8" Foreground="#CBE3DD" Text="Verification Station" />
                    <TextBlock Margin="0,0,0,8" Foreground="#CBE3DD" Text="Publish Receipts" />
                    <TextBlock Margin="0,0,0,24" Foreground="#CBE3DD" Text="Verification Receipts" />

                    <Border Background="#16463F"
                            CornerRadius="18"
                            Padding="14">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="Workspace Root" />
                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="#CBE3DD"
                                       Text="{Binding WorkspaceRoot}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}"
                    Background="{StaticResource HeroBrush}"
                    Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontFamily="Segoe UI Variable Display"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Text="Release cockpit foundation" />
                        <TextBlock Margin="0,8,0,10"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AppAccentDeepBrush}"
                                   Text="{Binding SummaryHeadline}" />
                        <TextBlock Width="680"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource AppTextMutedBrush}"
                                   Text="{Binding SummaryDetails}" />

                        <ItemsControl Margin="0,18,0,0"
                                      ItemsSource="{Binding PortfolioDashboardCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,12,12"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.ApplyDashboardCardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Border Width="150"
                                                Padding="14"
                                                Background="#FFFFFF"
                                                BorderBrush="{StaticResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <StackPanel>
                                                <TextBlock FontSize="11"
                                                           Foreground="{StaticResource AppTextMutedBrush}"
                                                           Text="{Binding Title}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           FontFamily="Segoe UI Variable Display"
                                                           FontSize="26"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource AppAccentDeepBrush}"
                                                           Text="{Binding CountDisplay}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Text="{Binding Detail}" />
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Margin="24,0,0,0"
                            Padding="14"
                            Background="#FFFFFF"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel Width="260">
                            <TextBlock FontWeight="SemiBold" Text="Local State" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding DatabasePath}" />
                            <TextBlock Margin="0,14,0,0"
                                       Foreground="{StaticResource AppSuccessBrush}"
                                       FontWeight="SemiBold"
                                       Text="{Binding StatusText}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding IsBusy, StringFormat=Busy: {0}}" />
                            <TextBlock Margin="0,12,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding PlanCoverageText}" />

                            <Border Margin="0,16,0,0"
                                    Padding="12"
                                    Background="#F4F9F7"
                                    BorderBrush="{StaticResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left"
                                                   FontWeight="SemiBold"
                                                   Text="Build Engine" />
                                        <Border DockPanel.Dock="Right"
                                                Padding="8,3"
                                                Background="#FFFFFF"
                                                BorderBrush="{StaticResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource AppTextMutedBrush}"
                                                       Text="{Binding BuildEngineStatus}" />
                                        </Border>
                                    </DockPanel>
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource AppAccentDeepBrush}"
                                               FontWeight="SemiBold"
                                               Text="{Binding BuildEngineHeadline}" />
                                    <TextBlock Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding BuildEngineDetails}" />
                                    <TextBlock Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppWarmBrush}"
                                               Text="{Binding BuildEngineAdvisory}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="18"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Background="{StaticResource AppSurfaceAltBrush}">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Managed Repositories" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="Live portfolio with readiness and git telemetry, persisted through DbaClientX.SQLite." />

                            <WrapPanel Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Quick Presets" />
                                    <ItemsControl Margin="0,6,0,0"
                                                  ItemsSource="{Binding PortfolioQuickPresets}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,10,10"
                                                        Padding="12,6"
                                                        Background="#FFFFFF"
                                                        BorderBrush="{StaticResource AppBorderBrush}"
                                                        BorderThickness="1"
                                                        Command="{Binding DataContext.ApplyPortfolioPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </WrapPanel>

                            <WrapPanel Margin="0,4,0,0">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Repository Families" />
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding RepositoryFamilyHeadline}" />
                                    <TextBlock Margin="0,2,0,0"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding RepositoryFamilyDetails}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource AppAccentDeepBrush}"
                                               FontWeight="SemiBold"
                                               Text="{Binding RepositoryFamilyActionHeadline}" />

                                    <ItemsControl Margin="0,8,0,0"
                                                  ItemsSource="{Binding RepositoryFamilies}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,10,10"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding DataContext.ApplyRepositoryFamilyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <Border Width="178"
                                                            Padding="12"
                                                            Background="#FFFFFF"
                                                            BorderBrush="{StaticResource AppBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="16">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <TextBlock DockPanel.Dock="Left"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding DisplayName}" />
                                                                <Border DockPanel.Dock="Right"
                                                                        Padding="8,3"
                                                                        Background="{StaticResource AppSurfaceAltBrush}"
                                                                        CornerRadius="10">
                                                                    <TextBlock FontSize="11"
                                                                               Foreground="{StaticResource AppTextMutedBrush}"
                                                                               Text="{Binding CountDisplay}" />
                                                                </Border>
                                                            </DockPanel>
                                                            <TextBlock Margin="0,6,0,0"
                                                                       Foreground="{StaticResource AppAccentDeepBrush}"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding StatusDisplay}" />
                                                            <TextBlock Margin="0,6,0,0"
                                                                       TextWrapping="Wrap"
                                                                       Style="{StaticResource MutedTextStyle}"
                                                                       Text="{Binding MemberSummary}" />
                                                        </StackPanel>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <WrapPanel Margin="0,2,0,0">
                                        <Button Margin="0,0,10,10"
                                                Padding="12,6"
                                                Background="#FFFFFF"
                                                BorderBrush="{StaticResource AppBorderBrush}"
                                                BorderThickness="1"
                                                Command="{Binding PrepareSelectedFamilyQueueCommand}"
                                                Content="Prepare Family Queue" />
                                        <Button Margin="0,0,10,10"
                                                Padding="12,6"
                                                Background="#FFFFFF"
                                                BorderBrush="{StaticResource AppBorderBrush}"
                                                BorderThickness="1"
                                                Command="{Binding RetrySelectedFamilyFailedCommand}"
                                                Content="Retry Family Failed" />
                                    </WrapPanel>

                                    <Border Margin="0,0,0,10"
                                            Padding="14"
                                            Background="#FFFFFF"
                                            BorderBrush="{StaticResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="Family Lane" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{StaticResource AppAccentDeepBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RepositoryFamilyLaneHeadline}" />
                                            <TextBlock Margin="0,4,0,12"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Text="{Binding RepositoryFamilyLaneDetails}" />

                                            <ItemsControl ItemsSource="{Binding RepositoryFamilyLaneItems}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Margin="0,0,0,10"
                                                                Padding="0"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Command="{Binding DataContext.ApplyRepositoryFamilyLaneItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}">
                                                            <Border Padding="12"
                                                                    Background="{StaticResource AppSurfaceAltBrush}"
                                                                    CornerRadius="14">
                                                                <StackPanel>
                                                                    <DockPanel>
                                                                        <TextBlock DockPanel.Dock="Left"
                                                                                   FontWeight="SemiBold"
                                                                                   Text="{Binding RepositoryName}" />
                                                                        <TextBlock DockPanel.Dock="Right"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource AppTextMutedBrush}"
                                                                                   Text="{Binding WorkspaceDisplay}" />
                                                                    </DockPanel>
                                                                    <TextBlock Margin="0,4,0,0"
                                                                               Foreground="{StaticResource AppAccentDeepBrush}"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding LaneDisplay}" />
                                                                    <TextBlock Margin="0,4,0,0"
                                                                               FontSize="11"
                                                                               Style="{StaticResource MutedTextStyle}"
                                                                               Text="{Binding ReadinessDisplay}" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               TextWrapping="Wrap"
                                                                               Text="{Binding Detail}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </WrapPanel>

                            <WrapPanel Margin="0,4,0,0">
                                <StackPanel Width="220">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Focus" />
                                    <ComboBox Margin="0,6,0,0"
                                              ItemsSource="{Binding PortfolioFocusModes}"
                                              SelectedItem="{Binding SelectedPortfolioFocus, Mode=TwoWay}"
                                              DisplayMemberPath="DisplayName" />
                                </StackPanel>

                                <StackPanel Width="280" Margin="14,0,0,0">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Search" />
                                    <TextBox Margin="0,6,0,0"
                                             Text="{Binding PortfolioSearchText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </WrapPanel>

                            <TextBlock Margin="0,14,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AppAccentDeepBrush}"
                                       Text="{Binding PortfolioFocusHeadline}" />
                            <TextBlock Margin="0,4,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AppAccentDeepBrush}"
                                       Text="{Binding PortfolioPresetHeadline}" />
                            <TextBlock Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding PortfolioViewMemory}" />
                            <TextBlock Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding PortfolioFocusDetails}" />
                        </StackPanel>
                    </Border>

                    <ListView ItemsSource="{Binding Repositories}"
                              SelectedItem="{Binding SelectedRepository, Mode=TwoWay}">
                        <ListView.View>
                            <GridView AllowsColumnReorder="False">
                                <GridViewColumn Width="220" Header="Repository" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Width="140" Header="Family" DisplayMemberBinding="{Binding FamilyDisplayName}" />
                                <GridViewColumn Width="110" Header="Readiness" DisplayMemberBinding="{Binding ReadinessKind}" />
                                <GridViewColumn Width="200" Header="Reason" DisplayMemberBinding="{Binding ReadinessReason}" />
                                <GridViewColumn Width="110" Header="Plan" DisplayMemberBinding="{Binding PlanStatus}" />
                                <GridViewColumn Width="320" Header="Plan Summary" DisplayMemberBinding="{Binding PlanSummary}" />
                                <GridViewColumn Width="110" Header="GitHub" DisplayMemberBinding="{Binding GitHubStatus}" />
                                <GridViewColumn Width="70" Header="PRs" DisplayMemberBinding="{Binding GitHubPullRequests}" />
                                <GridViewColumn Width="260" Header="GitHub Summary" DisplayMemberBinding="{Binding GitHubSummary}" />
                                <GridViewColumn Width="110" Header="Drift" DisplayMemberBinding="{Binding ReleaseDriftStatus}" />
                                <GridViewColumn Width="260" Header="Drift Summary" DisplayMemberBinding="{Binding ReleaseDriftSummary}" />
                                <GridViewColumn Width="180" Header="Branch" DisplayMemberBinding="{Binding BranchName}" />
                                <GridViewColumn Width="110" Header="Ahead / Behind" DisplayMemberBinding="{Binding AheadBehindDisplay}" />
                                <GridViewColumn Width="170" Header="Dirty" DisplayMemberBinding="{Binding DirtyStatus}" />
                                <GridViewColumn Width="110" Header="Kind" DisplayMemberBinding="{Binding RepositoryKind}" />
                                <GridViewColumn Width="120" Header="Workspace" DisplayMemberBinding="{Binding WorkspaceKind}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Column="2" Margin="20,0,0,0">
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Repository Detail" />
                        <Border DockPanel.Dock="Right"
                                Padding="8,3"
                                Background="#FFFFFF"
                                BorderBrush="{StaticResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource AppTextMutedBrush}"
                                       Text="{Binding RepositoryDetailReadiness}" />
                        </Border>
                    </DockPanel>

                    <TextBlock Margin="0,8,0,0"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentDeepBrush}"
                               Text="{Binding RepositoryDetailHeadline}" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding RepositoryDetailBadge}" />
                    <TextBlock Margin="0,8,0,12"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding RepositoryDetailReason}" />

                    <Border Margin="0,0,0,12"
                            Padding="12"
                            Background="{StaticResource AppSurfaceAltBrush}"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Repository Path" />
                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding RepositoryDetailPath}" />
                            <TextBlock Margin="0,12,0,0"
                                       FontWeight="SemiBold"
                                       Text="Git Branch" />
                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding RepositoryDetailBranch}" />
                            <TextBlock Margin="0,12,0,0"
                                       FontWeight="SemiBold"
                                       Text="Build Contract" />
                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding RepositoryDetailBuildContract}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,12"
                            Padding="12"
                            Background="{StaticResource AppSurfaceAltBrush}"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Latest Queue Checkpoint" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource AppAccentDeepBrush}"
                                       FontWeight="SemiBold"
                                       Text="{Binding RepositoryDetailQueueLane}" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding RepositoryDetailQueueCheckpoint}" />
                            <TextBlock Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding RepositoryDetailQueueSummary}" />
                            <TextBlock Margin="0,12,0,0"
                                       FontWeight="SemiBold"
                                       Text="Checkpoint Payload" />
                            <Border Margin="0,6,0,0"
                                    Padding="10"
                                    Background="#FFFFFF"
                                    BorderBrush="{StaticResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <ScrollViewer MaxHeight="150"
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBlock FontFamily="Consolas"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Text="{Binding RepositoryDetailQueuePayload}" />
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,12"
                            Padding="12"
                            Background="{StaticResource AppSurfaceAltBrush}"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Release Drift" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource AppAccentDeepBrush}"
                                       FontWeight="SemiBold"
                                       Text="{Binding RepositoryDetailReleaseDrift}" />
                            <TextBlock Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding RepositoryDetailReleaseDriftDetail}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,12"
                            Padding="12"
                            Background="#F4F9F7"
                            BorderBrush="{StaticResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Effective Build Engine" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource AppAccentDeepBrush}"
                                       FontWeight="SemiBold"
                                       Text="{Binding RepositoryDetailEngineDisplay}" />
                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding RepositoryDetailEnginePath}" />
                            <TextBlock Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource AppWarmBrush}"
                                       Text="{Binding RepositoryDetailEngineAdvisory}" />
                        </StackPanel>
                    </Border>

                    <TextBlock FontWeight="SemiBold"
                               Text="Adapter Evidence" />
                    <ItemsControl Margin="0,10,0,0"
                                  ItemsSource="{Binding SelectedRepositoryEvidence}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding AdapterDisplay}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AppTextMutedBrush}"
                                                       Text="{Binding StatusDisplay}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource AppAccentDeepBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Summary}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding Detail}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="Artifact Path" />
                                        <TextBlock Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding ArtifactPath}" />
                                        <TextBlock Margin="0,10,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="Output Tail" />
                                        <Border Margin="0,4,0,0"
                                                Padding="8"
                                                Background="#FFFFFF"
                                                BorderBrush="{StaticResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <TextBlock FontFamily="Consolas"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding OutputTail}" />
                                        </Border>
                                        <TextBlock Margin="0,10,0,0"
                                                   FontWeight="SemiBold"
                                                   Text="Error Tail" />
                                        <Border Margin="0,4,0,0"
                                                Padding="8"
                                                Background="#FFFFFF"
                                                BorderBrush="{StaticResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <TextBlock FontFamily="Consolas"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding ErrorTail}" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Release Inbox" />
                    <TextBlock Margin="0,4,0,14"
                               Style="{StaticResource MutedTextStyle}"
                               Text="A ranked action list that merges queue blockers, USB pauses, publish/verify-ready work, and remote pressure." />

                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentDeepBrush}"
                               Text="{Binding ReleaseInboxHeadline}" />
                    <TextBlock Margin="0,6,0,14"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding ReleaseInboxDetails}" />

                    <ItemsControl ItemsSource="{Binding ReleaseInboxItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,0,10"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.ApplyReleaseInboxItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <Border Padding="12"
                                            Background="{StaticResource AppSurfaceAltBrush}"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Title}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           FontSize="11"
                                                           Foreground="{StaticResource AppTextMutedBrush}"
                                                           Text="{Binding Badge}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,6,0,0"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource AppAccentDeepBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RepositoryName}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Text="{Binding Detail}" />
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="GitHub Inbox" />
                    <TextBlock Margin="0,4,0,14"
                               Style="{StaticResource MutedTextStyle}"
                               Text="A lightweight remote probe for open PRs, recent workflow health, and latest release tags." />

                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentDeepBrush}"
                               Text="{Binding GitHubInboxHeadline}" />
                    <TextBlock Margin="0,6,0,14"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding GitHubInboxDetails}" />

                    <ItemsControl ItemsSource="{Binding GitHubInboxItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Name}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AppTextMutedBrush}"
                                                       Text="{Binding GitHubStatus}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource AppAccentDeepBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding GitHubSummary}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding GitHubInbox.Detail}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Release Drift" />
                    <TextBlock Margin="0,4,0,14"
                               Style="{StaticResource MutedTextStyle}"
                               Text="A lightweight signal for repos that appear ahead of their last detected GitHub release boundary." />

                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentDeepBrush}"
                               Text="{Binding ReleaseDriftHeadline}" />
                    <TextBlock Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding ReleaseDriftDetails}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Publish Station" />
                    <TextBlock Margin="0,4,0,14"
                               Style="{StaticResource MutedTextStyle}"
                               Text="Publish runs only after signing succeeds, and only when the external-publish safety flag is enabled." />

                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentDeepBrush}"
                               Text="{Binding PublishHeadline}" />
                    <TextBlock Margin="0,6,0,14"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding PublishDetails}" />

                    <ItemsControl ItemsSource="{Binding PublishTargets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RepositoryName}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AppTextMutedBrush}"
                                                       Text="{Binding TargetKind}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource AppAccentDeepBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding TargetName}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Destination}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding SourcePath}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Verification Station" />
                    <TextBlock Margin="0,4,0,14"
                               Style="{StaticResource MutedTextStyle}"
                               Text="Verification runs after publish and checks whether the recorded external outcomes can be confirmed." />

                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentDeepBrush}"
                               Text="{Binding VerificationHeadline}" />
                    <TextBlock Margin="0,6,0,14"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding VerificationDetails}" />

                    <ItemsControl ItemsSource="{Binding VerificationTargets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RepositoryName}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AppTextMutedBrush}"
                                                       Text="{Binding TargetKind}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource AppAccentDeepBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding TargetName}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Destination}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding SourcePath}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Verification Receipts" />
                    <TextBlock Margin="0,4,0,14"
                               Style="{StaticResource MutedTextStyle}"
                               Text="These are the final evidence checks that decide whether a queue item can actually be marked complete." />

                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentDeepBrush}"
                               Text="{Binding VerificationReceiptHeadline}" />
                    <TextBlock Margin="0,6,0,14"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding VerificationReceiptDetails}" />

                    <ItemsControl ItemsSource="{Binding VerificationReceipts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RepositoryName}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AppTextMutedBrush}"
                                                       Text="{Binding Status}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource AppAccentDeepBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding TargetName}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Summary}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding DestinationDisplay}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Publish Receipts" />
                    <TextBlock Margin="0,4,0,14"
                               Style="{StaticResource MutedTextStyle}"
                               Text="Every publish outcome is persisted so verify reflects recorded external state, not just optimistic queue movement." />

                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentDeepBrush}"
                               Text="{Binding PublishReceiptHeadline}" />
                    <TextBlock Margin="0,6,0,14"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding PublishReceiptDetails}" />

                    <ItemsControl ItemsSource="{Binding PublishReceipts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RepositoryName}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AppTextMutedBrush}"
                                                       Text="{Binding Status}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource AppAccentDeepBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding TargetName}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Summary}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding DestinationDisplay}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Signing Station" />
                    <TextBlock Margin="0,4,0,14"
                               Style="{StaticResource MutedTextStyle}"
                               Text="USB-gated artifacts are collected here so approval is tied to concrete files, not memory." />

                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentDeepBrush}"
                               Text="{Binding SigningHeadline}" />
                    <TextBlock Margin="0,6,0,14"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding SigningDetails}" />

                    <ItemsControl ItemsSource="{Binding SigningArtifacts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RepositoryName}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AppTextMutedBrush}"
                                                       Text="{Binding ArtifactKind}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource AppAccentDeepBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding AdapterDisplay}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding DisplayName}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding ArtifactPath}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Signing Receipts" />
                    <TextBlock Margin="0,4,0,14"
                               Style="{StaticResource MutedTextStyle}"
                               Text="Each signing action is persisted so publish unlocks only after recorded outcomes exist." />

                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentDeepBrush}"
                               Text="{Binding ReceiptHeadline}" />
                    <TextBlock Margin="0,6,0,14"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding ReceiptDetails}" />

                    <ItemsControl ItemsSource="{Binding SigningReceipts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RepositoryName}" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AppTextMutedBrush}"
                                                       Text="{Binding Status}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{StaticResource AppAccentDeepBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding ArtifactName}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Summary}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding ArtifactPath}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Draft Queue" />
                    <TextBlock Margin="0,4,0,14"
                               Style="{StaticResource MutedTextStyle}"
                               Text="The queue should feel explicit, resumable, and safe around signing checkpoints." />

                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentDeepBrush}"
                               Text="{Binding QueueHeadline}" />
                    <TextBlock Margin="0,6,0,14"
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding QueueDetails}" />

                    <ItemsControl ItemsSource="{Binding DraftQueue}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RepositoryName}" />
                                            <Border DockPanel.Dock="Right"
                                                    Padding="8,3"
                                                    Background="#FFFFFF"
                                                    BorderBrush="{StaticResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <TextBlock FontSize="11"
                                                           Foreground="{StaticResource AppTextMutedBrush}"
                                                           Text="{Binding OrderDisplay}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource AppAccentDeepBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding LaneDisplay}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Text="{Binding RepositoryBadge}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Summary}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Execution Spine" />
                    <TextBlock Margin="0,4,0,14"
                               Style="{StaticResource MutedTextStyle}"
                               Text="These stages stay visible so build, sign, publish, and verify can evolve without hiding the queue state." />

                    <ItemsControl ItemsSource="{Binding PipelineStages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="{StaticResource AppSurfaceAltBrush}"
                                        CornerRadius="14">
                                    <TextBlock TextWrapping="Wrap" Text="{Binding}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Next PR Slices" />
                    <TextBlock Margin="0,4,0,14"
                               Style="{StaticResource MutedTextStyle}"
                               Text="Keep each increment additive so the branch can stay reviewable and low-risk." />

                    <ItemsControl ItemsSource="{Binding NextSlices}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,10"
                                           TextWrapping="Wrap"
                                           Text="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
