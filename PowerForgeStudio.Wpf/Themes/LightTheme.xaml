<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════ Light Theme Palette ═══════ -->
    <SolidColorBrush x:Key="AppShellBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#F9FAFB" />
    <SolidColorBrush x:Key="AppSurfaceHoverBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#E5E7EB" />
    <SolidColorBrush x:Key="AppTextStrongBrush" Color="#111827" />
    <SolidColorBrush x:Key="AppTextBrush" Color="#374151" />
    <SolidColorBrush x:Key="AppTextMutedBrush" Color="#9CA3AF" />
    <SolidColorBrush x:Key="AppAccentBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="AppAccentDeepBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="AppWarmBrush" Color="#D97706" />
    <SolidColorBrush x:Key="AppSuccessBrush" Color="#059669" />
    <SolidColorBrush x:Key="AppDangerBrush" Color="#DC2626" />

    <SolidColorBrush x:Key="AppScrollThumbBrush" Color="#D1D5DB" />
    <SolidColorBrush x:Key="AppTabHoverBrush" Color="#E5E7EB" />

    <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F9FAFB" Offset="0" />
        <GradientStop Color="#EFF6FF" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
