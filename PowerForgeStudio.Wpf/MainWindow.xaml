<Window x:Class="PowerForgeStudio.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:PowerForgeStudio.Wpf.ViewModels"
        xmlns:hub="clr-namespace:PowerForgeStudio.Wpf.ViewModels.Hub"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PowerForge Studio"
        Width="1600"
        Height="960"
        MinWidth="1280"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <!-- Dark title bar via DWM attribute -->
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0,1,0,0" CaptionHeight="32"
                      ResizeBorderThickness="6" UseAeroCaptionButtons="True" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <hub:BoolToVisibleConverter x:Key="BoolToVisible" />
        <hub:BoolToCollapsedConverter x:Key="BoolToCollapsed" />

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Padding" Value="10,5" />
        </Style>
        <Style x:Key="FlatList" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
        </Style>
        <Style x:Key="FlatItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AppSurfaceHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="Transparent" Padding="14,7" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AppAccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AppSurfaceHoverBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AppAccentDeepBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
            <Setter Property="Margin" Value="0,14,0,8" />
            <!-- Letter spacing handled by font weight -->
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppSurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,12" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppShellBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe UI Variable Display" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AppTextStrongBrush}"
                               VerticalAlignment="Center" Text="PowerForge Studio" Margin="0,0,20,0" />
                    <RadioButton Content="Hub" Style="{StaticResource NavBtn}"
                                 IsChecked="{Binding IsHubMode, Mode=OneWay}" GroupName="Mode"
                                 Command="{Binding SwitchToHubCommand}" />
                    <RadioButton Content="Release" Style="{StaticResource NavBtn}"
                                 IsChecked="{Binding IsReleaseMode, Mode=OneWay}" GroupName="Mode"
                                 Command="{Binding SwitchToReleaseCommand}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource AppTextMutedBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"
                               Text="{Binding HubViewModel.StatusText}" />
                    <ProgressBar Width="100" Height="3" IsIndeterminate="{Binding HubViewModel.IsScanning}"
                                 Background="{StaticResource AppSurfaceAltBrush}"
                                 Foreground="{StaticResource AppAccentBrush}" BorderThickness="0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ContentControl Grid.Row="1" Content="{Binding ActiveContent}">
            <ContentControl.Resources>

                <!-- ==================== HUB VIEW ==================== -->
                <DataTemplate DataType="{x:Type hub:HubViewModel}">
                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="360" />
                        </Grid.ColumnDefinitions>

                        <!-- ===== LEFT: Project List ===== -->
                        <Border Grid.Column="0" Background="{StaticResource AppSurfaceBrush}"
                                BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,1,0">
                            <DockPanel>
                                <!-- Header -->
                                <StackPanel DockPanel.Dock="Top" Margin="16,14,16,0">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AppTextStrongBrush}" Text="Projects" />
                                        <Button DockPanel.Dock="Right" Style="{StaticResource GhostBtn}"
                                                Padding="8,3" FontSize="11"
                                                Command="{Binding ScanWorkspaceCommand}" Content="Scan" />
                                    </DockPanel>
                                    <TextBox Margin="0,10,0,10" Padding="8,6" FontSize="12"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <!-- Project Tree -->
                                <ListBox Style="{StaticResource FlatList}"
                                         ItemContainerStyle="{StaticResource FlatItem}"
                                         ItemsSource="{Binding FilteredProjects}"
                                         SelectedItem="{Binding SelectedProject}"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         VirtualizingPanel.ScrollUnit="Pixel"
                                         ScrollViewer.CanContentScroll="True"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         Margin="8,0,8,8">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="8,6,8,4">
                                                <!-- Project Name + Time -->
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{StaticResource AppTextStrongBrush}"
                                                               Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock DockPanel.Dock="Right" FontSize="10" Margin="6,2,0,0"
                                                               Foreground="{StaticResource AppTextMutedBrush}"
                                                               Text="{Binding LastActivity}" />
                                                </DockPanel>
                                                <!-- Category + Branch + Badges -->
                                                <DockPanel Margin="0,3,0,0">
                                                    <Border DockPanel.Dock="Left" Padding="5,1" CornerRadius="4"
                                                            Background="{StaticResource AppSurfaceAltBrush}">
                                                        <TextBlock FontSize="10" Foreground="{StaticResource AppTextMutedBrush}"
                                                                   Text="{Binding CategoryDisplay}" />
                                                    </Border>
                                                    <!-- PR badge -->
                                                    <Border DockPanel.Dock="Right" Padding="5,1" CornerRadius="4" Margin="4,0,0,0"
                                                            Background="#1A3B82F6"
                                                            Visibility="{Binding HasOpenPrs, Converter={StaticResource BoolToVisible}}">
                                                        <TextBlock FontSize="9" Foreground="{StaticResource AppAccentBrush}"
                                                                   Text="{Binding OpenPrCount, StringFormat={}{0} PR}" />
                                                    </Border>
                                                    <TextBlock DockPanel.Dock="Left" FontSize="11" Margin="6,0,0,0"
                                                               Foreground="{StaticResource AppAccentBrush}"
                                                               Text="{Binding BranchName}" TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                                <!-- Worktrees (clickable) -->
                                                <ItemsControl ItemsSource="{Binding Worktrees}" Margin="10,4,0,0"
                                                              Visibility="{Binding HasWorktrees, Converter={StaticResource BoolToVisible}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,1" Padding="4,2" CornerRadius="4"
                                                                    Background="Transparent" Cursor="Hand"
                                                                    MouseLeftButtonDown="WorktreeItem_Click">
                                                                <DockPanel>
                                                                    <Ellipse Width="5" Height="5" Fill="{StaticResource AppSuccessBrush}"
                                                                             VerticalAlignment="Center" Margin="0,0,6,0" />
                                                                    <TextBlock FontSize="11"
                                                                               Foreground="{StaticResource AppTextMutedBrush}"
                                                                               Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock DockPanel.Dock="Right" FontSize="9" Margin="6,1,0,0"
                                                                               Foreground="{StaticResource AppTextMutedBrush}"
                                                                               Text="{Binding LastActivity}" />
                                                                </DockPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <!-- ===== CENTER: Workspace / Dashboard ===== -->
                        <Grid Grid.Column="1">
                            <!-- Dashboard -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20"
                                          Visibility="{Binding HasSelectedProject, Converter={StaticResource BoolToCollapsed}}">
                                <StackPanel MaxWidth="800">
                                    <TextBlock FontSize="22" FontWeight="SemiBold"
                                               Foreground="{StaticResource AppTextStrongBrush}" Text="Dashboard" />
                                    <TextBlock Margin="0,6,0,20" Style="{StaticResource MutedText}"
                                               Text="Select a project to view details. Aggregate stats below." />

                                    <!-- Stat Cards -->
                                    <UniformGrid Columns="3" Rows="2" Margin="0,0,0,20">
                                        <Border Style="{StaticResource StatCard}" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock FontSize="32" FontWeight="Bold"
                                                           Foreground="{StaticResource AppAccentBrush}"
                                                           Text="{Binding Dashboard.TotalProjects}" />
                                                <TextBlock FontSize="12" Foreground="{StaticResource AppTextMutedBrush}" Text="Total Projects" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource StatCard}" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock FontSize="32" FontWeight="Bold"
                                                           Foreground="{StaticResource AppAccentBrush}"
                                                           Text="{Binding Dashboard.ManagedProjects}" />
                                                <TextBlock FontSize="12" Foreground="{StaticResource AppTextMutedBrush}" Text="Managed" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource StatCard}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock FontSize="32" FontWeight="Bold"
                                                           Foreground="{StaticResource AppWarmBrush}"
                                                           Text="{Binding Dashboard.DirtyRepos}" />
                                                <TextBlock FontSize="12" Foreground="{StaticResource AppTextMutedBrush}" Text="Dirty Repos" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource StatCard}" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock FontSize="32" FontWeight="Bold"
                                                           Foreground="{StaticResource AppAccentBrush}"
                                                           Text="{Binding Dashboard.TotalOpenPrs}" />
                                                <TextBlock FontSize="12" Foreground="{StaticResource AppTextMutedBrush}" Text="Open PRs" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource StatCard}" Margin="0,0,8,8">
                                            <StackPanel>
                                                <TextBlock FontSize="32" FontWeight="Bold"
                                                           Foreground="{StaticResource AppAccentBrush}"
                                                           Text="{Binding Dashboard.TotalOpenIssues}" />
                                                <TextBlock FontSize="12" Foreground="{StaticResource AppTextMutedBrush}" Text="Open Issues" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource StatCard}" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock FontSize="32" FontWeight="Bold"
                                                           Foreground="{StaticResource AppDangerBrush}"
                                                           Text="{Binding Dashboard.FailingBuilds}" />
                                                <TextBlock FontSize="12" Foreground="{StaticResource AppTextMutedBrush}" Text="Failing Builds" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <TextBlock Style="{StaticResource SectionHead}" Text="RECENTLY ACTIVE" />
                                    <ItemsControl ItemsSource="{Binding Dashboard.RecentlyActive}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource AppSurfaceAltBrush}"
                                                        CornerRadius="8" Padding="12,8" Margin="0,0,0,4">
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" FontSize="13"
                                                                   Foreground="{StaticResource AppTextStrongBrush}"
                                                                   Text="{Binding Name}" />
                                                        <Border DockPanel.Dock="Right" Padding="6,2" CornerRadius="4"
                                                                Background="{StaticResource AppSurfaceHoverBrush}">
                                                            <TextBlock FontSize="10" Foreground="{StaticResource AppTextMutedBrush}"
                                                                       Text="{Binding CategoryDisplay}" />
                                                        </Border>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Project Workspace -->
                            <ContentControl Content="{Binding ActiveWorkspace}"
                                            Visibility="{Binding HasSelectedProject, Converter={StaticResource BoolToVisible}}">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate DataType="{x:Type hub:ProjectWorkspaceViewModel}">
                                        <DockPanel Margin="24,16,24,16">
                                            <!-- Workspace Header -->
                                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                                <StackPanel DockPanel.Dock="Left">
                                                    <TextBlock FontSize="20" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AppTextStrongBrush}"
                                                               Text="{Binding ProjectName}" />
                                                    <TextBlock FontSize="11" Foreground="{StaticResource AppTextMutedBrush}"
                                                               Text="{Binding RootPath}" Margin="0,2,0,0" />
                                                </StackPanel>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                            VerticalAlignment="Top" Margin="8,0,0,0">
                                                    <Button Style="{StaticResource GhostBtn}" Padding="8,4" FontSize="10"
                                                            Margin="0,0,4,0"
                                                            Command="{Binding OpenInExplorerCommand}" Content="Explorer" />
                                                    <Button Style="{StaticResource GhostBtn}" Padding="8,4" FontSize="10"
                                                            Margin="0,0,4,0"
                                                            Command="{Binding OpenInVsCodeCommand}" Content="VS Code" />
                                                    <Button Style="{StaticResource GhostBtn}" Padding="8,4" FontSize="10"
                                                            Command="{Binding OpenInTerminalCommand}" Content="Terminal" />
                                                </StackPanel>
                                            </DockPanel>

                                            <TabControl SelectedIndex="{Binding SelectedTabIndex}">
                                                <TabItem Header="Overview">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                                                        <StackPanel>
                                                            <!-- Info cards -->
                                                            <UniformGrid Columns="2" Margin="0,0,0,8">
                                                                <Border Style="{StaticResource StatCard}" Margin="0,0,6,0">
                                                                    <StackPanel>
                                                                        <TextBlock FontSize="10" Foreground="{StaticResource AppTextMutedBrush}" Text="BUILD" />
                                                                        <TextBlock Margin="0,4,0,0" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource AppAccentBrush}"
                                                                                   Text="{Binding BuildScriptDisplay}" />
                                                                    </StackPanel>
                                                                </Border>
                                                                <Border Style="{StaticResource StatCard}" Margin="6,0,0,0">
                                                                    <StackPanel>
                                                                        <TextBlock FontSize="10" Foreground="{StaticResource AppTextMutedBrush}" Text="REMOTE" />
                                                                        <TextBlock Margin="0,4,0,0" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource AppTextStrongBrush}"
                                                                                   Text="{Binding GitHubSlug}" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </UniformGrid>
                                                            <Border Style="{StaticResource StatCard}" Margin="0,0,0,8"
                                                                    Visibility="{Binding HasAzureDevOps, Converter={StaticResource BoolToVisible}}">
                                                                <StackPanel>
                                                                    <TextBlock FontSize="10" Foreground="{StaticResource AppTextMutedBrush}" Text="AZURE DEVOPS" />
                                                                    <TextBlock Margin="0,4,0,0" FontWeight="SemiBold"
                                                                               Foreground="{StaticResource AppTextStrongBrush}"
                                                                               Text="{Binding AzureDevOpsSlug}" />
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </TabItem>
                                                <TabItem Header="Issues">
                                                    <DockPanel Margin="0,12,0,0">
                                                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                                            <Button Style="{StaticResource GhostBtn}" DockPanel.Dock="Left"
                                                                    Command="{Binding LoadIssuesCommand}" Content="Refresh" />
                                                            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0"
                                                                       Foreground="{StaticResource AppTextMutedBrush}" FontSize="12"
                                                                       Text="{Binding Issues.Count, StringFormat={}{0} issue(s)}" />
                                                        </DockPanel>
                                                        <ListBox Style="{StaticResource FlatList}" ItemContainerStyle="{StaticResource FlatItem}"
                                                                 ItemsSource="{Binding Issues}">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="{StaticResource AppSurfaceAltBrush}"
                                                                            CornerRadius="8" Padding="12,8" Margin="0,0,0,2">
                                                                        <StackPanel>
                                                                            <DockPanel>
                                                                                <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" FontSize="13"
                                                                                           Foreground="{StaticResource AppTextStrongBrush}"
                                                                                           Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                                                                <TextBlock DockPanel.Dock="Right" FontSize="11"
                                                                                           Foreground="{StaticResource AppTextMutedBrush}"
                                                                                           Text="{Binding Number, StringFormat=#{0}}" />
                                                                            </DockPanel>
                                                                            <DockPanel Margin="0,4,0,0">
                                                                                <TextBlock FontSize="11" Foreground="{StaticResource AppAccentBrush}"
                                                                                           Text="{Binding LabelDisplay}" />
                                                                            </DockPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </DockPanel>
                                                </TabItem>
                                                <TabItem Header="Pull Requests">
                                                    <DockPanel Margin="0,12,0,0">
                                                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                                            <Button Style="{StaticResource GhostBtn}" DockPanel.Dock="Left"
                                                                    Command="{Binding LoadPullRequestsCommand}" Content="Refresh" />
                                                            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0"
                                                                       Foreground="{StaticResource AppTextMutedBrush}" FontSize="12"
                                                                       Text="{Binding PullRequests.Count, StringFormat={}{0} PR(s)}" />
                                                        </DockPanel>
                                                        <ListBox Style="{StaticResource FlatList}" ItemContainerStyle="{StaticResource FlatItem}"
                                                                 ItemsSource="{Binding PullRequests}">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="{StaticResource AppSurfaceAltBrush}"
                                                                            CornerRadius="8" Padding="12,8" Margin="0,0,0,2">
                                                                        <StackPanel>
                                                                            <DockPanel>
                                                                                <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" FontSize="13"
                                                                                           Foreground="{StaticResource AppTextStrongBrush}"
                                                                                           Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                                                                <TextBlock DockPanel.Dock="Right" FontSize="11"
                                                                                           Foreground="{StaticResource AppTextMutedBrush}"
                                                                                           Text="{Binding Number, StringFormat=#{0}}" />
                                                                            </DockPanel>
                                                                            <DockPanel Margin="0,4,0,0">
                                                                                <TextBlock FontSize="11" Foreground="{StaticResource AppAccentBrush}"
                                                                                           Text="{Binding HeadBranch}" />
                                                                                <TextBlock DockPanel.Dock="Right" FontSize="11"
                                                                                           Foreground="{StaticResource AppSuccessBrush}" Margin="8,0,0,0"
                                                                                           Text="{Binding DiffStatDisplay}" />
                                                                            </DockPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </DockPanel>
                                                </TabItem>
                                                <TabItem Header="Build">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                                                        <StackPanel>
                                                            <TextBlock Style="{StaticResource SectionHead}" Text="BUILD SCRIPT" />
                                                            <TextBlock Foreground="{StaticResource AppAccentBrush}" Text="{Binding BuildScriptDisplay}" />
                                                            <Button Margin="0,12,0,0" Style="{StaticResource GhostBtn}"
                                                                    Command="{Binding RunBuildCommand}" Content="Run Build" />
                                                            <TextBlock Style="{StaticResource SectionHead}" Text="OUTPUT" />
                                                            <TextBox IsReadOnly="True"
                                                                     FontFamily="Cascadia Code,Consolas,Courier New"
                                                                     FontSize="11" MaxHeight="400"
                                                                     TextWrapping="Wrap" AcceptsReturn="True"
                                                                     VerticalScrollBarVisibility="Auto"
                                                                     Text="{Binding BuildOutput, Mode=OneWay}" />
                                                        </StackPanel>
                                                    </ScrollViewer>
                                                </TabItem>
                                            </TabControl>
                                        </DockPanel>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </Grid>

                        <!-- ===== RIGHT: Git Actions Panel ===== -->
                        <Border Grid.Column="2" Background="{StaticResource AppSurfaceBrush}"
                                BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1,0,0,0">
                            <Grid>
                                <!-- Placeholder when nothing selected -->
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource AppTextMutedBrush}" FontSize="12"
                                           Text="Select a project to see git status."
                                           Visibility="{Binding HasSelectedProject, Converter={StaticResource BoolToCollapsed}}" />

                                <!-- Git Actions -->
                                <ContentControl Content="{Binding ActiveActions}"
                                                Visibility="{Binding HasSelectedProject, Converter={StaticResource BoolToVisible}}">
                                    <ContentControl.ContentTemplate>
                                        <DataTemplate DataType="{x:Type hub:ProjectActionsViewModel}">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,14">
                                                <StackPanel>
                                                    <!-- Branch + Diff Header -->
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Left" FontSize="11"
                                                                   Foreground="{StaticResource AppTextMutedBrush}"
                                                                   Text="{Binding AheadBehindDisplay}" />
                                                    </DockPanel>
                                                    <TextBlock FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0"
                                                               Foreground="{StaticResource AppTextStrongBrush}"
                                                               Text="{Binding BranchName}" />

                                                    <!-- Commit Box -->
                                                    <TextBox Margin="0,14,0,0" MinHeight="50" AcceptsReturn="True"
                                                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                                             FontSize="12"
                                                             Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}" />
                                                    <Button Margin="0,8,0,0" HorizontalAlignment="Left"
                                                            Style="{StaticResource GhostBtn}"
                                                            Command="{Binding CommitCommand}" Content="Commit" />

                                                    <!-- Staged -->
                                                    <TextBlock Style="{StaticResource SectionHead}" Text="STAGED" />
                                                    <ItemsControl ItemsSource="{Binding StagedChanges}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <DockPanel Margin="0,1">
                                                                    <Border DockPanel.Dock="Left" Width="18" Height="18"
                                                                            CornerRadius="4" Margin="0,0,8,0"
                                                                            Background="{StaticResource AppSuccessBrush}">
                                                                        <TextBlock Text="{Binding KindDisplay}" FontSize="10"
                                                                                   Foreground="White" HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center" FontWeight="Bold" />
                                                                    </Border>
                                                                    <TextBlock FontSize="12" Foreground="{StaticResource AppTextBrush}"
                                                                               Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                                                </DockPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- Unstaged -->
                                                    <DockPanel Margin="0,14,0,8">
                                                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource SectionHead}"
                                                                   Margin="0" Text="UNSTAGED" />
                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <Button Style="{StaticResource GhostBtn}" Padding="6,2" FontSize="10"
                                                                    Margin="0,0,4,0"
                                                                    Command="{Binding StageAllCommand}" Content="Stage All" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                    <ItemsControl ItemsSource="{Binding UnstagedChanges}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <DockPanel Margin="0,1">
                                                                    <Border DockPanel.Dock="Left" Width="18" Height="18"
                                                                            CornerRadius="4" Margin="0,0,8,0"
                                                                            Background="{StaticResource AppWarmBrush}">
                                                                        <TextBlock Text="{Binding KindDisplay}" FontSize="10"
                                                                                   Foreground="White" HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center" FontWeight="Bold" />
                                                                    </Border>
                                                                    <TextBlock FontSize="12" Foreground="{StaticResource AppTextBrush}"
                                                                               Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                                                </DockPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- Diff -->
                                                    <TextBlock Style="{StaticResource SectionHead}" Text="DIFF" />
                                                    <TextBox IsReadOnly="True" MaxHeight="180"
                                                             FontFamily="Cascadia Code,Consolas,Courier New"
                                                             FontSize="11" TextWrapping="NoWrap" AcceptsReturn="True"
                                                             HorizontalScrollBarVisibility="Auto"
                                                             VerticalScrollBarVisibility="Auto"
                                                             Text="{Binding DiffContent, Mode=OneWay}" />

                                                    <!-- Branches -->
                                                    <TextBlock Style="{StaticResource SectionHead}" Text="BRANCHES" />
                                                    <ComboBox Padding="6" FontSize="12"
                                                              ItemsSource="{Binding Branches}"
                                                              SelectedItem="{Binding SelectedBranch}" />
                                                    <Button Margin="0,6,0,0" Style="{StaticResource GhostBtn}"
                                                            HorizontalAlignment="Left"
                                                            Command="{Binding SwitchBranchCommand}" Content="Switch" />

                                                    <!-- Worktrees -->
                                                    <TextBlock Style="{StaticResource SectionHead}" Text="WORKTREES" />
                                                    <ItemsControl ItemsSource="{Binding Worktrees}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource AppSurfaceAltBrush}"
                                                                        CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                                                                    <StackPanel>
                                                                        <TextBlock FontWeight="SemiBold" FontSize="12"
                                                                                   Foreground="{StaticResource AppTextStrongBrush}"
                                                                                   Text="{Binding BranchDisplay}" />
                                                                        <TextBlock FontSize="10" Foreground="{StaticResource AppTextMutedBrush}"
                                                                                   Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- Refresh -->
                                                    <Button Margin="0,14,0,0" Style="{StaticResource GhostBtn}"
                                                            HorizontalAlignment="Left"
                                                            Command="{Binding RefreshStatusCommand}" Content="Refresh" />
                                                </StackPanel>
                                            </ScrollViewer>
                                        </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                </ContentControl>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>

                <!-- Release mode placeholder -->
                <DataTemplate DataType="{x:Type local:ShellViewModel}">
                    <TextBlock Margin="40" FontSize="16" Foreground="{StaticResource AppTextMutedBrush}"
                               Text="Release mode — switch to Hub to manage projects." />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
