<Window x:Class="PowerForgeStudio.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:PowerForgeStudio.Wpf.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PowerForgeStudio"
        Width="1600"
        Height="960"
        MinWidth="1280"
        MinHeight="820"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="#EDF6F2" />
            <Setter Property="BorderBrush" Value="#C9DDD4" />
            <Setter Property="Foreground" Value="{StaticResource AppAccentDeepBrush}" />
        </Style>
        <Style x:Key="FlatListBoxStyle" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style x:Key="FlatListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="ExplorerNodeBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#EDF6F2" />
                    <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Background="{StaticResource HeroBrush}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontFamily="Segoe UI Variable Display" FontSize="28" FontWeight="SemiBold" Text="PowerForge Studio" />
                    <TextBlock Margin="0,4,0,0" FontSize="16" Foreground="{StaticResource AppAccentDeepBrush}" Text="{Binding PortfolioOverview.SummaryHeadline}" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding PortfolioOverview.SummaryDetails}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock FontWeight="SemiBold" Text="Workspace Root" />
                    <ComboBox Margin="0,8,0,0" Padding="6" IsEditable="True" IsTextSearchEnabled="False"
                              ItemsSource="{Binding RecentWorkspaceRoots}" StaysOpenOnEdit="True"
                              Text="{Binding WorkspaceRoot, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Focus" />
                    <ComboBox Margin="0,8,0,0" Padding="6"
                              ItemsSource="{Binding PortfolioOverview.FocusModes}"
                              SelectedItem="{Binding PortfolioOverview.SelectedFocus}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="20,0,0,0">
                    <TextBlock FontWeight="SemiBold" Text="Search" />
                    <TextBox Margin="0,8,0,0" Padding="8,6" Text="{Binding PortfolioOverview.SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Plan Coverage" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding PortfolioOverview.PlanCoverageText}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="24,0,0,0">
                    <TextBlock FontWeight="SemiBold" Text="Quick Filters" />
                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding PortfolioOverview.QuickPresets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding DataContext.ApplyPortfolioPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Content="{Binding DisplayName}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Status" />
                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource AppAccentBrush}" FontWeight="SemiBold" Text="{Binding StatusText}" />
                    <ProgressBar Margin="0,10,0,0" Height="8" IsIndeterminate="{Binding IsBusy}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Margin="0,0,16,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Explorer" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding PortfolioOverview.FocusHeadline}" />
                            <WrapPanel Margin="0,12,0,0">
                                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding RefreshPortfolioCommand}" Content="Refresh Workspace" />
                                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding PrepareSelectedFamilyQueueCommand}" Content="Prepare Family" />
                                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding RetrySelectedFamilyFailedCommand}" Content="Retry Family" />
                            </WrapPanel>

                            <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Families" />
                            <TreeView Margin="0,10,0,0"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      ItemsSource="{Binding WorkspaceExplorerNodes}">
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate DataType="{x:Type local:WorkspaceExplorerNodeViewModel}" ItemsSource="{Binding Children}">
                                        <Button Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.ApplyWorkspaceExplorerNodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Border Style="{StaticResource ExplorerNodeBorderStyle}">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                        <Border DockPanel.Dock="Right" Padding="8,3" Background="#FFFFFF" CornerRadius="10">
                                                            <TextBlock Text="{Binding Badge}" />
                                                        </Border>
                                                    </DockPanel>
                                                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource AppAccentDeepBrush}" Text="{Binding Summary}" />
                                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding Detail}" />
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </HierarchicalDataTemplate>
                                </TreeView.Resources>
                            </TreeView>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelBorderStyle}" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Release Inbox" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding ReleaseSignals.ReleaseInboxHeadline}" />
                            <ListBox Margin="0,10,0,0" Style="{StaticResource FlatListBoxStyle}" ItemContainerStyle="{StaticResource FlatListItemStyle}"
                                     ItemsSource="{Binding ReleaseSignals.ReleaseInboxItems}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Button Padding="0" Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.ApplyReleaseInboxItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Border Padding="12" Background="#FFFDF9" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="14">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="{Binding RepositoryName}" />
                                                        <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource AppAccentBrush}" Text="{Binding Badge}" />
                                                    </DockPanel>
                                                    <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="{Binding Title}" />
                                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding Detail}" />
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="1" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="300" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" FontSize="18" FontWeight="SemiBold" Text="Repositories" />
                                    <Border DockPanel.Dock="Right" Padding="10,4" Background="#FFFFFF" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="10">
                                        <TextBlock Text="{Binding Repositories.Count, StringFormat=Visible repos: {0}}" />
                                    </Border>
                                </DockPanel>
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource HintTextStyle}" Text="Select a repository to inspect what you are actually working on." />
                            </StackPanel>

                            <ListBox Margin="0,16,0,0" Style="{StaticResource FlatListBoxStyle}" ItemContainerStyle="{StaticResource FlatListItemStyle}"
                                     ItemsSource="{Binding Repositories}" SelectedItem="{Binding SelectedRepository}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12" Background="#FFFFFF" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="14">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="{Binding Name}" />
                                                    <Border DockPanel.Dock="Right" Padding="8,3" Background="#EDF6F2" CornerRadius="10">
                                                        <TextBlock Text="{Binding ReadinessKind}" />
                                                    </Border>
                                                </DockPanel>
                                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource AppAccentDeepBrush}" Text="{Binding FamilyDisplayName}" />
                                                <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding ReadinessReason}" />
                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding PlanStatus, StringFormat=Plan: {0}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Family Lane" />
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding RepositoryFamily.LaneHeadline}" />
                            </StackPanel>
                            <ListBox Margin="0,16,0,0" Style="{StaticResource FlatListBoxStyle}" ItemContainerStyle="{StaticResource FlatListItemStyle}"
                                     ItemsSource="{Binding RepositoryFamily.LaneItems}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Button Padding="0" Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.ApplyRepositoryFamilyLaneItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Border Padding="12" Background="#FFFFFF" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="14">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding RepositoryName}" />
                                                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource AppAccentBrush}" Text="{Binding LaneDisplay}" />
                                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding Detail}" />
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Margin="0,16,0,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top">
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding RepositoryDetail.Headline}" />
                                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource AppAccentBrush}" FontWeight="SemiBold" Text="{Binding RepositoryDetail.Readiness}" />
                                </StackPanel>
                                <Border DockPanel.Dock="Right" Padding="10,4" Background="#FFFFFF" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="12">
                                    <TextBlock Text="{Binding RepositoryDetail.Badge}" />
                                </Border>
                            </DockPanel>
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding RepositoryDetail.Reason}" />
                        </StackPanel>

                        <TabControl Margin="0,16,0,0">
                            <TabItem Header="Overview">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="12">
                                        <TextBlock FontWeight="SemiBold" Text="Repository Path" />
                                        <TextBox Margin="0,8,0,0" IsReadOnly="True" Text="{Binding RepositoryDetail.Path}" />
                                        <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Branch" />
                                        <TextBlock Margin="0,8,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding RepositoryDetail.Branch}" />
                                        <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Queue" />
                                        <TextBlock Margin="0,8,0,0" Foreground="{StaticResource AppAccentBrush}" Text="{Binding RepositoryDetail.QueueLane}" />
                                        <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding RepositoryDetail.QueueSummary}" />
                                        <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Release Drift" />
                                        <TextBlock Margin="0,8,0,0" Foreground="{StaticResource AppAccentBrush}" Text="{Binding RepositoryDetail.ReleaseDrift}" />
                                        <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding RepositoryDetail.ReleaseDriftDetail}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Git">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="12">
                                        <TextBlock FontWeight="SemiBold" Text="Git Diagnostics" />
                                        <TextBlock Margin="0,8,0,0" Foreground="{StaticResource AppAccentBrush}" Text="{Binding RepositoryDetail.GitDiagnostics}" />
                                        <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding RepositoryDetail.GitDiagnosticsDetail}" />
                                        <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Quick Actions" />
                                        <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding RepositoryDetail.GitQuickActions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10" Padding="12" Background="#FFFFFF" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="14">
                                                        <DockPanel>
                                                            <StackPanel DockPanel.Dock="Left">
                                                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding Summary}" />
                                                            </StackPanel>
                                                            <Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}"
                                                                    Command="{Binding DataContext.ExecuteGitQuickActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}" Content="{Binding ExecuteLabel}" />
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Suggested Commands" />
                                        <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding RepositoryDetail.GitRemediationSteps}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10" Padding="12" Background="#FFFFFF" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="14">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="{Binding Title}" />
                                                                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}"
                                                                        Command="{Binding DataContext.CopyGitRemediationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}" Content="Copy" />
                                                            </DockPanel>
                                                            <TextBlock Margin="0,6,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding Summary}" />
                                                            <TextBox Margin="0,8,0,0" IsReadOnly="True" Text="{Binding CommandText}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Evidence">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="12">
                                        <TextBlock FontWeight="SemiBold" Text="Build Contract" />
                                        <TextBlock Margin="0,8,0,0" Foreground="{StaticResource AppAccentBrush}" Text="{Binding RepositoryDetail.BuildContract}" />
                                        <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Build Engine" />
                                        <TextBlock Margin="0,8,0,0" Foreground="{StaticResource AppAccentBrush}" Text="{Binding RepositoryDetail.EngineDisplay}" />
                                        <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding RepositoryDetail.EnginePath}" />
                                        <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding RepositoryDetail.Evidence}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10" Padding="12" Background="#FFFFFF" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="14">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="{Binding AdapterDisplay}" />
                                                                <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource AppAccentBrush}" Text="{Binding StatusDisplay}" />
                                                            </DockPanel>
                                                            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="{Binding Summary}" />
                                                            <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding Detail}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </DockPanel>
                </Border>
            </Grid>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Queue Control" />
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding Stations.QueueHeadline}" />
                            <WrapPanel Margin="0,12,0,0">
                                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding RunNextQueueStepCommand}" Content="Run Next" />
                                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding ApproveUsbCommand}" Content="Approve USB" />
                                <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding RetryFailedCommand}" Content="Retry Failed" />
                            </WrapPanel>
                            <ListBox Margin="0,14,0,0" Style="{StaticResource FlatListBoxStyle}" ItemContainerStyle="{StaticResource FlatListItemStyle}"
                                     ItemsSource="{Binding Stations.DraftQueue}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Button Padding="0" Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.ApplyQueueItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Border Padding="12" Background="#FFFFFF" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="14">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="{Binding RepositoryName}" />
                                                        <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource AppAccentBrush}" Text="{Binding OrderDisplay}" />
                                                    </DockPanel>
                                                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource AppAccentBrush}" Text="{Binding LaneDisplay}" />
                                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding Summary}" />
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <TabControl Margin="0,16,0,0" SelectedIndex="{Binding SelectedStageIndex}">
                        <TabItem Header="Sign">
                            <ItemsControl Margin="12" ItemsSource="{Binding Stations.SigningArtifacts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Padding="0" Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.ApplySigningArtifactCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Border Margin="0,0,0,10" Padding="12" Background="#FFFFFF" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="14">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding RepositoryName}" />
                                                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource AppAccentBrush}" Text="{Binding DisplayName}" />
                                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding ArtifactPath}" />
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </TabItem>
                        <TabItem Header="Publish">
                            <ItemsControl Margin="12" ItemsSource="{Binding Stations.PublishTargets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Padding="0" Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.ApplyPublishTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Border Margin="0,0,0,10" Padding="12" Background="#FFFFFF" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="14">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding RepositoryName}" />
                                                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource AppAccentBrush}" Text="{Binding TargetName}" />
                                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding Destination}" />
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </TabItem>
                        <TabItem Header="Verify">
                            <ItemsControl Margin="12" ItemsSource="{Binding Stations.VerificationTargets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Padding="0" Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.ApplyVerificationTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Border Margin="0,0,0,10" Padding="12" Background="#FFFFFF" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="14">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding RepositoryName}" />
                                                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource AppAccentBrush}" Text="{Binding DisplayName}" />
                                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="{Binding Destination}" />
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
