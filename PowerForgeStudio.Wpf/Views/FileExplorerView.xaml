<UserControl x:Class="PowerForgeStudio.Wpf.Views.FileExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hub="clr-namespace:PowerForgeStudio.Wpf.ViewModels.Hub">
    <UserControl.Resources>
        <hub:BoolToVisibleConverter x:Key="BoolToVisible" />

        <!-- Tree item style -->
        <Style x:Key="DarkTreeItem" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="Foreground" Value="#B8BDD0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd" Background="Transparent" Padding="4,2" CornerRadius="4" Margin="0,1">
                                <DockPanel>
                                    <ToggleButton DockPanel.Dock="Left" Focusable="False"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent" BorderThickness="0"
                                                  Width="14" Height="14"
                                                  Visibility="{Binding HasItems, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisible}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Padding="2">
                                                    <Path x:Name="arrow" Data="M0,0 L4,3.5 L0,7"
                                                          Stroke="#6B7280" StrokeThickness="1.2"
                                                          VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="arrow" Property="Data" Value="M0,0 L7,0 L3.5,4" />
                                                        <Setter TargetName="arrow" Property="Stroke" Value="#B8BDD0" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter ContentSource="Header" Margin="3,0,0,0" VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>
                            <ItemsPresenter Margin="14,0,0,0" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#242838" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#1A1D2A" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#0F1117">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Path bar -->
        <Border Grid.Row="0" Background="#161822" BorderBrush="#2A2E3F" BorderThickness="0,0,0,1" Padding="8,5">
            <DockPanel>
                <Button DockPanel.Dock="Left" Background="#1C1F2E" Foreground="#B8BDD0" BorderThickness="0"
                        Padding="8,3" FontSize="11" Margin="0,0,6,0"
                        Command="{Binding NavigateUpCommand}" Content="Up" />
                <Button DockPanel.Dock="Right" Background="#1C1F2E" Foreground="#B8BDD0" BorderThickness="0"
                        Padding="8,3" FontSize="11" Margin="6,0,0,0"
                        Command="{Binding RefreshCommand}" Content="Refresh" />
                <TextBox DockPanel.Dock="Right" Width="130" Margin="6,0,0,0"
                         FontSize="11" Padding="6,3"
                         Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#6B7280"
                           Text="{Binding CurrentPath}" TextTrimming="CharacterEllipsis" Margin="4,0,0,0" />
            </DockPanel>
        </Border>

        <!-- Two pane -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Folder tree -->
            <TreeView Grid.Column="0" Background="#161822" BorderThickness="0"
                      Foreground="#B8BDD0"
                      ItemsSource="{Binding RootNodes}"
                      ItemContainerStyle="{StaticResource DarkTreeItem}"
                      SelectedItemChanged="TreeView_SelectedItemChanged"
                      Padding="4">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xF0114;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="#F59E0B" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}" Margin="5,0,0,0"
                                       Foreground="#B8BDD0" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="2" Background="#2A2E3F"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Right: File list -->
            <ListView Grid.Column="2" Background="#0F1117" BorderThickness="0"
                      ItemsSource="{Binding CurrentFolderContents}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      Foreground="#B8BDD0"
                      MouseDoubleClick="ListView_MouseDoubleClick"
                      Padding="0">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="#161822" />
                                <Setter Property="Foreground" Value="#6B7280" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="BorderBrush" Value="#2A2E3F" />
                                <Setter Property="Padding" Value="10,5" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GridViewColumnHeader">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Header="Name" Width="350">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="2,0">
                                        <TextBlock Width="14" TextAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#xE7C3;" />
                                                    <Setter Property="Foreground" Value="#6B7280" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                            <Setter Property="Text" Value="&#xF0114;" />
                                                            <Setter Property="Foreground" Value="#F59E0B" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Name}" Margin="8,0,0,0"
                                                   Foreground="#E8ECF4" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Size" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeDisplay}" Foreground="#6B7280" FontSize="11" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Modified" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LastModifiedDisplay}" Foreground="#6B7280" FontSize="11" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Foreground" Value="#B8BDD0" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="Bd" Background="Transparent" Padding="2,3" CornerRadius="0">
                                        <GridViewRowPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#242838" />
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True" />
                                                <Condition Property="IsSelected" Value="False" />
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bd" Property="Background" Value="#1A1D2A" />
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ContextMenu>
                    <ContextMenu Background="#1C1F2E" Foreground="#B8BDD0" BorderBrush="#2A2E3F">
                        <MenuItem Header="Open in Explorer"
                                  Command="{Binding OpenInExplorerCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}" />
                        <MenuItem Header="Copy Path"
                                  Command="{Binding CopyPathCommand}"
                                  CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}" />
                    </ContextMenu>
                </ListView.ContextMenu>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
