<UserControl x:Class="PowerForgeStudio.Wpf.Views.MarkdownPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="320"
             d:DesignWidth="640"
             MinHeight="140"
             MinWidth="160">
    <Grid>
        <wv2:WebView2 x:Name="Browser"
                      Visibility="Collapsed" />

        <Border x:Name="StatusOverlay"
                Background="{DynamicResource AppSurfaceAltBrush}"
                Padding="16">
            <TextBlock x:Name="StatusText"
                       Foreground="{DynamicResource AppTextMutedBrush}"
                       Text="Loading markdown preview..."
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
