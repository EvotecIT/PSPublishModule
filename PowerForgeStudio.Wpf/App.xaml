<Application x:Class="PowerForgeStudio.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <Color x:Key="AppShellColor">#F3EFE8</Color>
        <Color x:Key="AppSurfaceColor">#FFFDF9</Color>
        <Color x:Key="AppSurfaceAltColor">#E7ECE9</Color>
        <Color x:Key="AppBorderColor">#D0D8D3</Color>
        <Color x:Key="AppTextStrongColor">#18302B</Color>
        <Color x:Key="AppTextMutedColor">#58706A</Color>
        <Color x:Key="AppAccentColor">#156F63</Color>
        <Color x:Key="AppAccentDeepColor">#0D4A42</Color>
        <Color x:Key="AppWarmColor">#D9772B</Color>
        <Color x:Key="AppSuccessColor">#2A8F63</Color>

        <SolidColorBrush x:Key="AppShellBrush" Color="{StaticResource AppShellColor}" />
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
        <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="{StaticResource AppSurfaceAltColor}" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorderColor}" />
        <SolidColorBrush x:Key="AppTextStrongBrush" Color="{StaticResource AppTextStrongColor}" />
        <SolidColorBrush x:Key="AppTextMutedBrush" Color="{StaticResource AppTextMutedColor}" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="{StaticResource AppAccentColor}" />
        <SolidColorBrush x:Key="AppAccentDeepBrush" Color="{StaticResource AppAccentDeepColor}" />
        <SolidColorBrush x:Key="AppWarmBrush" Color="{StaticResource AppWarmColor}" />
        <SolidColorBrush x:Key="AppSuccessBrush" Color="{StaticResource AppSuccessColor}" />

        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F7FBF8" Offset="0" />
            <GradientStop Color="#DCEEE8" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource AppShellBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AppTextStrongBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="ListView">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}" />
        </Style>
    </Application.Resources>
</Application>
